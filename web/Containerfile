# ── Stage 1: Build ──────────────────────────────────────────────────
FROM node:22-slim AS builder

WORKDIR /build

# Copy root project files first (for ToneForge CLI build)
COPY package.json package-lock.json tsconfig.json ./
COPY src/ src/

# Install root project dependencies and build CLI
RUN npm ci --ignore-scripts && npm run build

# Copy web project files
COPY web/package.json web/package-lock.json web/
COPY web/vite.config.ts web/tsconfig.json web/tsconfig.server.json web/
COPY web/src/ web/src/
COPY web/server/ web/server/

# Install web dependencies and build
WORKDIR /build/web
RUN npm ci --ignore-scripts && npm run build

# ── Stage 2: Runtime ────────────────────────────────────────────────
FROM node:22-slim

# Install bash for PTY (slim images have dash by default)
RUN apt-get update && apt-get install -y --no-install-recommends bash \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for PTY shell
RUN useradd --create-home --shell /bin/bash demouser

WORKDIR /app

# Copy built CLI (needed by the terminal to run ToneForge commands)
COPY --from=builder /build/package.json /build/package-lock.json ./
COPY --from=builder /build/dist/ dist/
COPY --from=builder /build/src/ src/
RUN npm ci --omit=dev --ignore-scripts

# Copy web server and built frontend
COPY --from=builder /build/web/dist/ web/dist/
COPY --from=builder /build/web/dist-server/ web/dist-server/
COPY --from=builder /build/web/package.json /build/web/package-lock.json web/
WORKDIR /app/web
RUN npm ci --omit=dev --ignore-scripts

WORKDIR /app

# Set ownership so demouser can access project files
RUN chown -R demouser:demouser /app

ENV PORT=3000
ENV ALLOWED_ORIGINS=localhost,127.0.0.1
EXPOSE 3000

USER demouser

CMD ["node", "web/dist-server/index.js"]
