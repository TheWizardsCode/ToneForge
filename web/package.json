{
  "name": "toneforge-web-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Web-based demo for ToneForge CLI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && vite build --mode development 2>&1 | head -1"
  },
  "dependencies": {
    "express": "^5.1.0",
    "ws": "^8.18.2",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-attach": "^0.11.0",
    "node-pty": "^1.0.0",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "vite": "^6.3.5",
    "typescript": "^5.9.3",
    "@types/express": "^5.0.2",
    "@types/ws": "^8.18.1",
    "@types/node": "^22.15.0"
  }
}
